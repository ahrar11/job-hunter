# ──────────────────────────────────────────────────────────────
# Job Hunter — Environment Variables
# Copy to .env locally. NEVER commit .env — it's in .gitignore.
# In GitHub, add each as a Repository Secret (Settings → Secrets).
# ──────────────────────────────────────────────────────────────

# ── Job source APIs ────────────────────────────────────────────
# JSearch: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free: 200 req/month
JSEARCH_API_KEY=your_rapidapi_key_here

# Adzuna: https://developer.adzuna.com/
# Free: 1,000 req/month
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ── Gemini (resume scoring + tailoring) ────────────────────────
# https://aistudio.google.com/app/apikey  — Free: 1,500 req/day
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email (Resend — works from any email, no SMTP, no org blocks)
# 1. Sign up free at https://resend.com
# 2. Create an API key → paste below
# 3. RESEND_FROM_EMAIL must be a verified domain OR use onboarding@resend.dev
#    for testing (only delivers to the email you signed up with).
#    For production: verify ahrar@bu.edu or use a personal Gmail.
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
