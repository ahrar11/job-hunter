# ──────────────────────────────────────────────────────────────
# Job Hunter — Environment Variables
# Copy to .env locally. NEVER commit .env — it's in .gitignore.
# In GitHub, add each as a Repository Secret (Settings → Secrets).
# ──────────────────────────────────────────────────────────────

# ── Job source APIs ────────────────────────────────────────────
# JSearch: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free: 200 req/month
JSEARCH_API_KEY=your_rapidapi_key_here

# Adzuna: https://developer.adzuna.com/
# Free: 1,000 req/month
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ── LLM (Anthropic Claude — resume scoring + tailoring) ────────
# https://console.anthropic.com — Free: $5 credits
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Email (Resend — works from any email, no SMTP, no org blocks)
# 1. Sign up free at https://resend.com
# 2. Create an API key → paste below
# 3. RESEND_FROM_EMAIL must be a verified domain OR use onboarding@resend.dev
#    for testing (only delivers to the email you signed up with).
#    For production: verify a custom domain in Resend dashboard.
# 4. RESEND_TO_EMAIL must match your Resend signup email when using
#    onboarding@resend.dev as sender (Resend error 1010 otherwise).
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=your_resend_signup_email@example.com

# ── Dashboard Feedback (GitHub fine-grained PAT) ──────────────
# Enables Applied/Saved/Skipped buttons to sync back to the repo.
# 1. github.com → Settings → Developer settings → Fine-grained tokens
# 2. Create token scoped to ONLY this repo (ahrar11/job-hunter)
# 3. Permissions: Contents → Read and Write
# 4. Add as GitHub Secret: GITHUB_FEEDBACK_TOKEN
GITHUB_FEEDBACK_TOKEN=github_pat_your_token_here
